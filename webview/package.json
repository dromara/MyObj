{
  "name": "myobj-webview",
  "private": true,
  "version": "1.0.0",
  "description": "MyObj网盘系统",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .eslintignore",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .eslintignore",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,vue,json,css,scss,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,vue,json,css,scss,md}\" --ignore-path .prettierignore",
    "code-check": "pnpm run type-check && pnpm run lint:check && pnpm run format:check",
    "analyze": "pnpm run build:prod && node scripts/build-analysis.js",
    "clean": "rm -rf node_modules packages/*/node_modules dist"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@myobj/api": "workspace:*",
    "@myobj/hooks": "workspace:*",
    "@myobj/http": "workspace:*",
    "@myobj/shared": "workspace:*",
    "@myobj/ui": "workspace:*",
    "axios": "^1.16.1",
    "driver.js": "^1.4.0",
    "element-plus": "^2.14.0",
    "highlight.js": "^11.11.1",
    "jsencrypt": "^3.5.4",
    "pinia": "^3.0.4",
    "plyr": "^3.8.4",
    "spark-md5": "^3.0.2",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/spark-md5": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/typescript-plugin": "^3.2.9",
    "autoprefixer": "^10.5.0",
    "code-inspector-plugin": "^1.5.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.13",
    "vite-plugin-compression": "^0.5.1"
  }
}
